<!-- pages/analysis/index.wxml - 疲劳度趋势分析 -->
<view class="container">

  <!-- 未连接设备警告 -->
  <view class="conn-warning" wx:if="{{!isConnected}}">
    <text class="conn-warning-text">未连接设备，请先在"网络配置"页连接</text>
  </view>

  <!-- 1. 时间范围筛选 -->
  <view class="filter-bar">
    <scroll-view class="filter-scroll" scroll-x>
      <view class="filter-chips">
        <view wx:for="{{dateRange}}" wx:key="key"
          class="filter-chip {{selectedRange === item.key ? 'active' : ''}}"
          data-key="{{item.key}}" bindtap="onRangeChange">{{item.label}}</view>
      </view>
    </scroll-view>
  </view>

  <view class="date-range-bar">
    <block wx:if="{{selectedRange === 'custom'}}">
      <view class="custom-dt-row">
        <text class="dt-label">开始</text>
        <picker mode="date" value="{{customStartDate}}" bindchange="onCustomStartChange">
          <view class="picker-btn dt-date">{{customStartDate || '日期'}}</view>
        </picker>
        <picker mode="time" value="{{customStartTime}}" bindchange="onCustomStartTimeChange">
          <view class="picker-btn dt-time">{{customStartTime || '00:00'}}</view>
        </picker>
      </view>
      <view class="custom-dt-row">
        <text class="dt-label">结束</text>
        <picker mode="date" value="{{customEndDate}}" bindchange="onCustomEndChange">
          <view class="picker-btn dt-date">{{customEndDate || '日期'}}</view>
        </picker>
        <picker mode="time" value="{{customEndTime}}" bindchange="onCustomEndTimeChange">
          <view class="picker-btn dt-time">{{customEndTime || '23:59'}}</view>
        </picker>
        <view class="query-btn query-btn-sm" bindtap="onQuery"><text>查询</text></view>
      </view>
    </block>
    <block wx:else>
      <text class="date-range-text">{{startDate}} ~ {{endDate}}</text>
      <view class="btn-group">
        <view class="query-btn" bindtap="onQuery"><text>查询</text></view>
      </view>
    </block>
  </view>

  <!-- 查询结果提示 -->
  <view class="query-result-tip" wx:if="{{queryResultTip}}">
    <text>{{queryResultTip}}</text>
  </view>

  <!-- 数据统计 -->
  <view class="stats-bar" wx:if="{{statsInfo}}">
    <view class="stats-item stats-good">
      <view class="stats-value-row">
        <text class="stats-value">{{statsInfo.goodCount}}</text>
        <text class="stats-sub">{{statsInfo.goodPct}}%</text>
      </view>
      <text class="stats-label">正常</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item stats-warn">
      <view class="stats-value-row">
        <text class="stats-value">{{statsInfo.warnCount}}</text>
        <text class="stats-sub">{{statsInfo.warnPct}}%</text>
      </view>
      <text class="stats-label">轻度疲劳</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item stats-danger">
      <view class="stats-value-row">
        <text class="stats-value">{{statsInfo.dangerCount}}</text>
        <text class="stats-sub">{{statsInfo.dangerPct}}%</text>
      </view>
      <text class="stats-label">重度疲劳</text>
    </view>
  </view>

  <!-- ========== 内容区 ========== -->
  <view class="content-area">

    <!-- 已连接状态 -->
    <block wx:if="{{isConnected}}">

      <!-- 加载状态 -->
      <view class="loading-state" wx:if="{{isLoading}}">
        <view class="spinner"></view>
        <text class="loading-text">正在查询数据...</text>
      </view>

      <!-- 空数据状态 -->
      <view class="empty-state" wx:elif="{{isEmpty}}">
        <text class="empty-title">该时间范围内无数据</text>
        <text class="empty-desc">{{errorMsg || '连接设备后选择时间范围查询'}}</text>
      </view>

      <!-- 数据展示 -->
      <block wx:elif="{{!isEmpty}}">

        <!-- 汇总分析卡 -->
        <view class="summary-card-full conclusion-{{conclusion.level}}">

          <view class="summary-data-row">
            <view class="summary-data-item">
              <text class="summary-data-value">{{conclusion.peakText}}</text>
              <text class="summary-data-label">峰值疲劳度</text>
            </view>
            <view class="summary-data-divider"></view>
            <view class="summary-data-item">
              <text class="summary-data-value">{{summary.peakTime}}</text>
              <text class="summary-data-label">峰值时间</text>
            </view>
            <view class="summary-data-divider"></view>
            <view class="summary-data-item">
              <text class="summary-data-value">{{conclusion.durationText}}</text>
              <text class="summary-data-label">监测时长</text>
            </view>
          </view>

          <view class="summary-status-row">
            <view class="summary-status-main">
              <text class="summary-icon">{{conclusion.levelIcon}}</text>
              <text class="summary-status-text">{{conclusion.levelText}}</text>
            </view>
            <text class="summary-trend-tag trend-type-{{trend.type}}">{{trend.typeText}}</text>
          </view>

          <view class="summary-desc">
            <text>{{trend.description}}</text>
          </view>

          <view class="summary-suggestion">
            <text class="sugg-icon">💡</text>
            <text class="sugg-text">{{conclusion.suggestion}}</text>
          </view>
        </view>

        <!-- 疲劳度趋势图 -->
        <view class="chart-section">
          <view class="chart-header">
            <text class="chart-title">疲劳度趋势 (%)</text>
            <view class="chart-legend">
              <view class="legend-item"><view class="legend-dot good"></view><text>正常</text></view>
              <view class="legend-item"><view class="legend-dot warn"></view><text>轻度疲劳</text></view>
              <view class="legend-item"><view class="legend-dot danger"></view><text>严重疲劳</text></view>
            </view>
          </view>
          <canvas type="2d" id="fatigueChart" class="chart-canvas"></canvas>
        </view>

        <!-- 操作栏 -->
        <view class="action-bar">
          <button class="btn btn-secondary" bindtap="onExportData" wx:if="{{!showShareBtn}}">导出原始数据</button>
          <button class="btn btn-primary" wx:if="{{showShareBtn}}" bindtap="onShareToWechat">发送到微信</button>
        </view>
      </block>

    </block>

    <!-- 未连接时的提示 -->
    <view class="empty-state" wx:else>
      <text class="empty-title">连接设备后查看数据分析</text>
      <text class="empty-desc">支持按时间范围查询监测数据、疲劳度趋势分布</text>
    </view>

  </view>

</view>