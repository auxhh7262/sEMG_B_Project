/* pages/network/index.wxss — V3.0 */
.container {
  padding: 20rpx 30rpx;
  min-height: 100vh;
  background: #0f0f0f;
  color: #e0e0e0;
  font-size: 28rpx;
}

/* Status card */
.status-card {
  display: flex;
  align-items: center;
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.status-indicator {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.status-indicator.idle    { background: #666; }
.status-indicator.scanning { background: #378ADD; animation: pulse 1s infinite; }
.status-indicator.connecting { background: #EF9F27; animation: pulse 0.5s infinite; }
.status-indicator.connected { background: #1D9E75; }
.status-indicator.failed  { background: #E24B4A; }
.status-indicator.configuring { background: #EF9F27; }

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.status-info {
  flex: 1;
}
.status-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #e0e0e0;
  display: block;
  margin-bottom: 4rpx;
}
.status-sub {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-top: 4rpx;
}

/* Action section */
.action-section {
  margin-bottom: 30rpx;
  text-align: center;
}
.hint {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-top: 16rpx;
}

/* Config section */
.config-section {
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

/* Device info */
.device-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #2a2a2a;
}
.device-info:last-child {
  border-bottom: none;
}
.label {
  color: #888;
  font-size: 26rpx;
}
.value {
  color: #e0e0e0;
  font-size: 26rpx;
  font-weight: 500;
  font-family: monospace;
}

/* Input group */
.input-group {
  margin-bottom: 36rpx;
}
.input-group .label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}
.input {
  background: #2a2a2a;
  border-radius: 12rpx;
  padding: 28rpx 32rpx;
  color: #e0e0e0;
  font-size: 32rpx;
  min-height: 88rpx;
  width: 100%;
  box-sizing: border-box;
  line-height: 1.4;
}

/* Buttons */
.btn-primary {
  background: #378ADD;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  margin: 16rpx 0;
  border: none;
}
.btn-primary[disabled] {
  background: #2a4a6a;
  color: #666;
}

.btn-secondary {
  background: #2a2a2a;
  color: #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  border: none;
}

.btn-danger {
  background: #3a1515;
  color: #E24B4A;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  border: none;
}

.btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}
.btn-row button {
  flex: 1;
  margin: 0;
}

/* Progress steps */
.progress-section {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  margin-bottom: 30rpx;
}
.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.step-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #333;
  margin-bottom: 8rpx;
}
.step.active .step-dot {
  background: #378ADD;
}
.step.done .step-dot {
  background: #1D9E75;
}
.step-text {
  font-size: 20rpx;
  color: #555;
}
.step.active .step-text {
  color: #378ADD;
}
.step.done .step-text {
  color: #1D9E75;
}
.step-line {
  width: 80rpx;
  height: 2rpx;
  background: #333;
  margin: 0 8rpx 28rpx 8rpx;
}
.step.done + .step-line,
.step.active + .step-line {
  background: #1D9E75;
}

/* Connected section */
.connected-section {
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

/* Help section */
.help-section {
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}
.help-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #e0e0e0;
  display: block;
  margin-bottom: 16rpx;
}
.help-text {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-bottom: 8rpx;
}
